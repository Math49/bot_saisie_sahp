# Copie ce fichier en ".env" et renseigne les valeurs.
# Le fichier .env ne doit JAMAIS etre versionne (voir .gitignore).

# Token du bot Discord (Portail developpeur > Bot > Reset Token)
DISCORD_TOKEN=

# URI de connexion MongoDB
# Exemple local   : mongodb://127.0.0.1:27017/coffre_sahp
# Exemple Atlas   : mongodb+srv://user:password@cluster.xxxx.mongodb.net/coffre_sahp
MONGODB_URI=
